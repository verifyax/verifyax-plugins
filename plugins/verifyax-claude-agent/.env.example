# --- Adapter (the Claude agent A2A endpoint) ---
# Bearer token VerifyAX must present on message/send. Use a long random string.
# For continuity across restarts, keep this value FIXED and reuse it (with a stable
# URL) so the persisted VerifyAX agent registration keeps reconnecting.
# NEVER put your VerifyAX API key here — this is a public inbound credential; keep it
# a dedicated, throwaway-scope secret.
A2A_API_KEY=change-me-to-a-long-random-string
# A2A_ALLOW_NO_AUTH=1        # local dev ONLY (no inbound auth)

# Which Claude agent to expose:
CLAUDE_PROJECT_DIR=.          # dir whose CLAUDE.md + memory define "your" agent
CLAUDE_MODEL=claude-opus-4-8  # claude-opus-4-8 | claude-sonnet-5 | claude-haiku-4-5-20251001
# CLAUDE_TURN_TIMEOUT=240      # seconds per turn; raise for Opus / tools-on cold starts
#                             # (keep the VerifyAX agent timeout ABOVE this)
CLAUDE_TOOLS=off              # off = pure conversation (no sandbox) | on = autonomous tools
# CLAUDE_TOOLS=on is REFUSED unless CVX_SANDBOX_CONFIRMED=1 (the sandbox image sets it).
# CVX_SANDBOX_CONFIRMED=1     # ONLY inside the disposable sandbox

# Card identity (optional):
AGENT_NAME=Claude Agent under evaluation
# AGENT_DESCRIPTION=...

# Set only to force a fixed public origin (else derived from the request/tunnel).
# For CONTINUITY, use a stable URL here (a named tunnel or hosting) so the persisted
# VerifyAX registration reconnects across restarts:
# PUBLIC_BASE_URL=https://your-stable-host.example.com

# Optional tunnel hardening (scripts/tunnel.py): pin the cloudflared version and/or
# verify its checksum instead of pulling an unverified 'latest'.
# CLOUDFLARED_VERSION=2025.x.x
# CLOUDFLARED_SHA256=<expected-sha256-of-the-release-asset>

# --- VerifyAX (used by the verifyax-api skill during the eval steps) ---
VERIFYAX_API_KEY=sk-ver-api-...
